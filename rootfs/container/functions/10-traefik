runas() {
    sudo -Eu traefik yq -i "$@"
}

traefik_bootstrap_filesystem() {
    create_folder \
                    "${DATA_PATH},\
                    ${CONFIG_PATH},\
                    ${CONFIG_CUSTOM_PATH},\
                    ${ACME_STORAGE_PATH},\
                    ${LOG_PATH}" \
                    traefik:traefik 755

    if var_true "${ENABLE_CERTIFICATE_EXPORTER}" ; then
        create_folder \
                        "${CERTIFICATE_EXPORT_PATH}" \
                        traefik:traefik 755
    fi
}

traefik_configure_monitoring() {
    if var_true "${CONTAINER_ENABLE_MONITORING}" ; then
        source /container/base/defaults/*-monitoring
        case "${CONTAINER_MONITORING_BACKEND,,}" in
            "zabbix" )
                cat <<EOF | silent tee "${ZABBIX_CONFIG_PATH%/}"/"${ZABBIX_CONFIG_FILE}.d"/nfrastack_traefik.conf
# Zabbix traefik Configuration - Automatically Generated
# Find Companion Zabbix Server Templates at https://github.com/nfrastack/container-traefik
# Autoregister=traefik
EOF
            ;;
        esac
    fi
}

traefik_generate_configuration() {
    if [ "${SETUP_TYPE,,}" = "auto" ]; then
        transform_var file \
                        ACME_EMAIL \
                        ACME_WILDCARD_DOMAINS \
                        DASHBOARD_AUTHENTICATION_BASICADMIN_PASS \
                        DASHBOARD_AUTHENTICATION_BASIC_ADMIN_USER \
                        DASHBOARD_HOSTNAME \
                        DOCKER_ENDPOINT \
                        DOCKER_USERNAME \
                        DOCKER_PASSWORD \
                        DOCKER_DEFAULT_NETWORK

        ## TODO - Overwrite CF_API_EMAIL/CF_API_KEY with our own envs and then pass through upon container start
        if var_true "${TLS_ENABLE_ACME}"; then
            sanity_var ACME_EMAIL "ACME Email address"
            if [ "${ACME_CHALLENGE,,}" = "dns" ]; then
                sanity_var ACME_DNS_PROVIDER "ACME DNS Provider"
            fi
        fi

        print_warn "Autogenerating Configuration File"
        cat <<EOF | silent sudo -u traefik tee "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
## nfrastack/traefik
## Custom Generated Traefik configuration file for version 3.x. Do not edit, instead set ENV Vars
## If you want to use your own config.yml file set 'SETUP_TYPE=MANUAL' when starting container
## Last Generated on $(TZ=${TIMEZONE} date +'%Y-%m-%d %H:%M:%S %Z')
##

EOF

        runas   '
                    .global.checkNewVersion = env(CHECK_NEW_VERSION) |
                    .global.sendAnonymousUsage = env(SEND_ANONYMOUS_USAGE)
                ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

        runas   '
                    .serversTransport.insecureSkipVerify = env(SERVER_TRANSPORT_INSECURE_SKIP_VERIFY)
                ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

        ### Entrypoints
        #### HTTP
        print_debug "HTTP Enable"
        if var_true "${ENABLE_HTTP}"; then
            runas   '
                        .entryPoints[env(HTTP_ENTRYPOINT)].address = "'$(echo "${HTTP_LISTEN_IP}:${HTTP_LISTEN_PORT}")'" |
                        .entryPoints[env(HTTP_ENTRYPOINT)].transport.respondingTimeouts.readTimeout = env(HTTP_TIMEOUT_READ) |
                        .entryPoints[env(HTTP_ENTRYPOINT)].transport.respondingTimeouts.writeTimeout = env(HTTP_TIMEOUT_WRITE) |
                        .entryPoints[env(HTTP_ENTRYPOINT)].transport.respondingTimeouts.idleTimeout = env(HTTP_TIMEOUT_IDLE) |
                        .entryPoints[env(HTTP_ENTRYPOINT)].transport.lifeCycle.requestAcceptGraceTimeout = env(HTTP_TIMEOUT_LIFECYCLE_ACCEPT_GRACE) |
                        .entryPoints[env(HTTP_ENTRYPOINT)].transport.lifeCycle.graceTimeout = env(HTTP_TIMEOUT_LIFECYCLE_GRACE)
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            if var_true "${HTTP_ENABLE_PROXY_PROTOCOL}"; then
                runas   '
                            .entryPoints[env(HTTP_ENTRYPOINT)].ProxyProtocol.trustedIPs = [ "'$(echo "${TRUSTED_IPS//,/\",\"}")'" ]
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            if var_true "${HTTP_ENABLE_FORWARDED_HEADERS}"; then
                runas   '
                            .entryPoints[env(HTTP_ENTRYPOINT)].forwardedHeaders.trustedIPs = [ "'$(echo "${TRUSTED_IPS//,/\",\"}")'" ]
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            if var_true "${HTTP_ENABLE_COMPRESSION}" ; then
                middleware_file="${CONFIG_CUSTOM_PATH}/compression-http.yml"
                if [ ! -f "${middleware_file}" ]; then sudo -u traefik touch "${middleware_file}" ; fi
                runas   '
                            .http.middlewares.compression-http.compress = {}
                        ' "${middleware_file}"

                if [ -n "${HTTP_COMPRESSION_INCLUDE}" ]; then
                    runas   '
                                .http.middlewares.compression-http.compress.includedContentTypes = [ "'$(echo "${HTTP_COMPRESSION_INCLUDE//,/\",\"}")'" ]
                            ' "${middleware_file}"
                fi

                if [ -n "${HTTP_COMPRESSION_EXCLUDE}" ]; then
                    runas   '
                                .http.middlewares.compression-http.compress.excludedContentTypes = [ "'$(echo "${HTTP_COMPRESSION_EXCLUDE//,/\",\"}")'" ]
                            ' "${middleware_file}"
                fi

                if [ -n "${HTTP_COMPRESSION_MINIMUM_RESPONSE_BODY_BYTES}" ]; then
                    runas   '
                                .http.middlewares.compression-http.compress.minResponseBodyBytes = env(HTTP_COMPRESSION_MINIMUM_RESPONSE_BODY_BYTES)
                            ' "${middleware_file}"
                fi

                http_middleware="${http_middleware} compression-http@file"
            fi
        fi

        if var_true "${ENABLE_HTTPS}"; then
            #### HTTPS Upgrade
            print_debug "{HTTPS Upgrade}"
            if var_true "${HTTPS_ENABLE_UPGRADE}"; then
                #runas   '
                #            .http.middlewares.redirect_https.redirectScheme.scheme = "https"
                #        ' "${CONFIG_PATH}/${CONFIG_FILE}"
                #http_middleware="${http_middleware} redirect_https"

                runas   '
                            .entryPoints[env(HTTP_ENTRYPOINT)].http.redirections.entrypoint.to = env(HTTPS_ENTRYPOINT) |
                            .entryPoints[env(HTTP_ENTRYPOINT)].http.redirections.entrypoint.scheme = "https" |
                            .entryPoints[env(HTTP_ENTRYPOINT)].http.redirections.entrypoint.permanent = true
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            runas   '
                        .entryPoints[env(HTTPS_ENTRYPOINT)].address = "'$(echo "${HTTPS_LISTEN_IP}:${HTTPS_LISTEN_PORT}")'" |
                        .entryPoints[env(HTTPS_ENTRYPOINT)].transport.respondingTimeouts.readTimeout = env(HTTPS_TIMEOUT_READ) |
                        .entryPoints[env(HTTPS_ENTRYPOINT)].transport.respondingTimeouts.writeTimeout = env(HTTPS_TIMEOUT_WRITE) |
                        .entryPoints[env(HTTPS_ENTRYPOINT)].transport.respondingTimeouts.idleTimeout = env(HTTPS_TIMEOUT_IDLE) |
                        .entryPoints[env(HTTPS_ENTRYPOINT)].transport.lifeCycle.requestAcceptGraceTimeout = env(HTTPS_TIMEOUT_LIFECYCLE_ACCEPT_GRACE) |
                        .entryPoints[env(HTTPS_ENTRYPOINT)].transport.lifeCycle.graceTimeout = env(HTTPS_TIMEOUT_LIFECYCLE_GRACE)
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            if var_true "${HTTPS_ENABLE_PROXY_PROTOCOL}"; then
                runas   '
                            .entryPoints[env(HTTPS_ENTRYPOINT)].ProxyProtocol.trustedIPs = [ "'$(echo "${TRUSTED_IPS//,/\",\"}")'" ]
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            if var_true "${HTTPS_ENABLE_FORWARDED_HEADERS}"; then
                runas   '
                            .entryPoints[env(HTTPS_ENTRYPOINT)].forwardedHeaders.trustedIPs = [ "'$(echo "${TRUSTED_IPS//,/\",\"}")'" ]
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            if var_true "${HTTPS_ENABLE_COMPRESSION}" ; then
                middleware_file="${CONFIG_CUSTOM_PATH}/compression-https.yml"
                if [ ! -f "${middleware_file}" ]; then sudo -u traefik touch "${middleware_file}" ; fi
                runas   '
                            .http.middlewares.compression-https.compress = {}
                        ' "${middleware_file}"

                if [ -n "${HTTPS_COMPRESSION_INCLUDE}" ]; then
                    runas   '
                                .http.middlewares.compression-https.compress.includedContentTypes = [ "'$(echo "${HTTPS_COMPRESSION_INCLUDE//,/\",\"}")'" ]
                            ' "${middleware_file}"
                fi

                if [ -n "${HTTPS_COMPRESSION_EXCLUDE}" ]; then
                    runas   '
                                .http.middlewares.compression-https.compress.excludedContentTypes = [ "'$(echo "${HTTPS_COMPRESSION_EXCLUDE//,/\",\"}")'" ]
                            ' "${middleware_file}"
                fi

                if [ -n "${HTTPS_COMPRESSION_MINIMUM_RESPONSE_BODY_BYTES}" ]; then
                    runas   '
                                .http.middlewares.compression-https.compress.minResponseBodyBytes = env(HTTPS_COMPRESSION_MINIMUM_RESPONSE_BODY_BYTES)
                            ' "${middleware_file}"
                fi

                https_middleware="${https_middleware} compression-https@file"
            fi

            print_debug "HTTPS Entrypoint: ACME"
            if var_true "${TLS_ENABLE_ACME}" || var_true "${ENABLE_ACME}" ; then
                runas   '
                            .entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.options = env(ACME_TLS_PROFILE) |
                            .entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.certResolver = env(ACME_RESOLVER_NAME)
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi

            if [ -n "${ACME_WILDCARD_DOMAINS}" ]; then
                for wildcard_domain in $(echo ${ACME_WILDCARD_DOMAINS} | tr "," "\n" | uniq); do
                     runas  '
                                .entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.domains += [ { "main": "'$(echo "${wildcard_domain}")'" , "sans": [ "*.'$(echo "${wildcard_domain}")'" ] }]
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                done
            fi
        fi

        if var_true "${ENABLE_HTTP3}" ; then
                runas   '
                            .entryPoints[env(HTTPS_ENTRYPOINT)].http3.advertisedPort = env(HTTP3_LISTEN_PORT)
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        if var_true "${ENABLE_METRICS}" ; then
                runas   '
                            .entryPoints[env(METRICS_ENTRYPOINT)].address = "'$(echo "${METRICS_LISTEN_IP}:${METRICS_LISTEN_PORT}")'"
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        ### Build Middlewares
        if [ -n "${http_middleware}" ] ; then
            http_middlewares="$(echo "${http_middleware}" | sed -e "s|^ ||g" -e "s| |,|g")"
        fi

        if [ -n "${HTTP_MIDDLEWARES}" ] && [ -n "${http_middlewares}" ]; then
            http_middlewares="${http_middlewares},${HTTP_MIDDLEWARES}"
        elif
            [ -n "${HTTP_MIDDLEWARES}" ] && [ -z "${http_middlewares}" ]; then
            http_middlewares="${HTTP_MIDDLEWARES}"
        fi

        if [ -n "${http_middlewares}" ] ; then
            runas   '
                        .entryPoints[env(HTTP_ENTRYPOINT)].http.middlewares = [ "'$(echo "${http_middlewares//,/\",\"}")'" ]
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        if [ -n "${https_middleware}" ] ; then
            https_middlewares="$(echo "${https_middleware}" | sed -e "s|^ ||g" -e "s| |,|g")"
        fi

        if [ -n "${HTTPS_MIDDLEWARES}" ] && [ -n "${https_middlewares}" ]; then
            https_middlewares="${https_middlewares},${HTTPS_MIDDLEWARES}"
        elif
            [ -n "${HTTPS_MIDDLEWARES}" ] && [ -z "${https_middlewares}" ]; then
            https_middlewares="${HTTPS_MIDDLEWARES}"
        fi

        if [ -n "${https_middlewares}" ] ; then
            runas   '
                        .entryPoints[env(HTTPS_ENTRYPOINT)].http.middlewares = [ "'$(echo "${https_middlewares//,/\",\"}")'" ]
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        ### TLS Profiles

        export TLS_PROFILE_RUNTIME_MINIMUM_VERSION="TLS_PROFILE_${TLS_PROFILE^^}_MINIMUM_VERSION"
        export TLS_PROFILE_RUNTIME_MINIMUM_VERSION="${!TLS_PROFILE_RUNTIME_MINIMUM_VERSION}"
        export TLS_PROFILE_RUNTIME_ENABLE_SNI_STRICT="TLS_PROFILE_${TLS_PROFILE^^}_ENABLE_SNI_STRICT"
        export TLS_PROFILE_RUNTIME_ENABLE_SNI_STRICT="${!TLS_PROFILE_RUNTIME_ENABLE_SNI_STRICT}"
        export TLS_PROFILE_RUNTIME_CURVE_PREFERENCES="TLS_PROFILE_${TLS_PROFILE^^}_CURVE_PREFERENCES"
        export TLS_PROFILE_RUNTIME_CURVE_PREFERENCES="${!TLS_PROFILE_RUNTIME_CURVE_PREFERENCES}"
        export TLS_PROFILE_RUNTIME_CIPHERS="TLS_PROFILE_${TLS_PROFILE^^}_CIPHERS"
        export TLS_PROFILE_RUNTIME_CIPHERS="${!TLS_PROFILE_RUNTIME_CIPHERS}"

        runas   '
                    .tls.options.default.MinVersion = env(TLS_PROFILE_RUNTIME_MINIMUM_VERSION) |
                    .tls.options.default.sniStrict = env(TLS_PROFILE_RUNTIME_ENABLE_SNI_STRICT) |
                    .tls.options.default.curvePreferences = [ "'$(echo "${TLS_PROFILE_RUNTIME_CURVE_PREFERENCES//,/\",\"}")'" ] |
                    .tls.options.default.CipherSuites = [ "'$(echo "${TLS_PROFILE_RUNTIME_CIPHERS//,/\",\"}")'" ]
                ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

        if var_true "${TLS_ENABLE_TAILSCALE}"; then
            runas   '
                        .certificatesResolvers[env(TLS_TAILSCALE_RESOLVER_NAME)].tailscale = {}
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        tlscertnum=$(printenv | sort | grep -c '^TLS_.*_CERT_FILE')
        for (( i = 01; i <= tlscertnum; i++ )) ; do
            sudo -u traefik touch "${CONFIG_CUSTOM_PATH%/}"/tls-certs.yml
            i=$(printf "%02d" $i)
            if [ -v TLS_${i}_CERT ] ; then TLS_CERT_FILE=TLS_${i}_CERT ; else TLS_CERT_FILE=TLS_${i}_CERT_FILE ; fi
            if [ -v TLS_${i}_KEY ] ; then TLS_KEY_FILE=TLS_${i}_KEY ; else TLS_KEY_FILE=TLS_${i}_KEY_FILE ; fi
            if [ -n "${TLS_CERT_FILE}" ] && [ -n "${TLS_KEY_FILE}" ]; then
                exists=$(yq '.entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.certificates[] | select(.certFile == "'"${!TLS_CERT_FILE}"'" and .keyFile == "'"${!TLS_KEY_FILE}"'")' "${CONFIG_CUSTOM_PATH%/}"/tls-certs.yml)
                if [ -z "$exists" ]; then
                    runas   '
                            .entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.certificates += [{"certFile": "'"${!TLS_CERT_FILE}"'", "keyFile": "'"${!TLS_KEY_FILE}"'"}]
                            ' "${CONFIG_CUSTOM_PATH%/}"/tls-certs.yml
                fi
            fi
        done

        if [ -n "${TLS_CERT_PATH}" ]; then
            for crt in "${TLS_CERT_PATH%/}"/*.crt; do
                [ -e "$crt" ] || continue  # skip if no .crt files
                sudo -u traefik touch "${CONFIG_CUSTOM_PATH%/}"/tls-certs.yml
                key="${crt%.crt}.key"
                if [ -f "$key" ]; then
                    exists=$(yq '.entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.certificates[] | select(.certFile == "'"$crt"'" and .keyFile == "'"$key"'")' "${CONFIG_CUSTOM_PATH%/}"/tls-certs.yml)
                    if [ -z "$exists" ]; then
                        runas '
                          .entryPoints[env(HTTPS_ENTRYPOINT)].http.tls.certificates += [{"certFile": "'"$crt"'", "keyFile": "'"$key"'"}]
                        ' "${CONFIG_CUSTOM_PATH%/}"/tls-certs.yml
                    fi
                fi
            done
        fi

	    #### ACME Support
        print_debug "ACME Setup"
	    if var_true "${ENABLE_ACME}"; then
		    if [ ! -d "${ACME_STORAGE_PATH}" ]; then
                mkdir -p "${ACME_STORAGE_PATH}"
            fi
            if [ "$(stat -c %U "${ACME_STORAGE_PATH}")" != "traefik" ] ; then chown traefik:traefik "${ACME_STORAGE_PATH}" ; fi
            touch "${ACME_STORAGE_PATH%/}"/"${ACME_STORAGE_FILE}"
            chown "${TRAEFIK_USER}" "${ACME_STORAGE_PATH%/}"/"${ACME_STORAGE_FILE}"
            chmod 0600 "${ACME_STORAGE_PATH%/}"/"${ACME_STORAGE_FILE}"
            sanity_var ACME_EMAIL "ACME Email Address"
            runas   '
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.email = env(ACME_EMAIL) |
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.storage = "'$(echo "${ACME_STORAGE_PATH}/${ACME_STORAGE_FILE}")'" |
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.KeyType = env(ACME_KEYTYPE) |
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.certificatesDuration = env(ACME_CERTIFICATES_DURATION) |
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.clientTimeout = env(ACME_CLIENT_TIMEOUT) |
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.clientResponseHeaderTimeout = env(ACME_CLIENT_RESPONSE_HEADER_TIMEOUT)
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            case "${ACME_PROVIDER,,}" in
                "letsencrypt")
                    export ACME_SERVER="https://acme-v02.api.letsencrypt.org/directory"
                ;;
                "letsencrypt-staging" )
                    export ACME_SERVER="https://acme-staging-v02.api.letsencrypt.org/directory"
                ;;
                * )
                    sanity_var ACME_SERVER "ACME_SERVER must be populated"
                    exit 1
                ;;
            esac

            runas   '
                        .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.caServer = env(ACME_SERVER)
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            case "${ACME_CHALLENGE,,}" in
                "tls")
                    runas   '
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.tlsChallenge = {}
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                ;;
                "http")
                    runas   '
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.httpChallenge.entryPoint = env(HTTP_ENTRYPOINT)
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                ;;
                "dns")
                    sanity_var ACME_DNS_PROVIDER "ACME DNS Provider"
                    runas   '
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.dnsChallenge.provider = env(ACME_DNS_PROVIDER) |
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.dnsChallenge.propagation.delayBeforeChecks = env(ACME_DNS_PROPAGATION_DELAY_BEFORE_CHECKS) |
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.dnsChallenge.propagation.disableANSChecks = env(ACME_DNS_PROPAGATION_DISABLE_ANS_CHECKS) |
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.dnsChallenge.propagation.disableChecks = env(ACME_DNS_PROPAGATION_DISABLE_CHECKS) |
                                .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.dnsChallenge.propagation.requireAllRNS = env(ACME_DNS_PROPAGATION_REQUIRE_ALL_RNS)
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

                    if [ -n "${ACME_DNS_RESOLVER}" ]; then
                        runas   '
                                    .certificatesResolvers[env(ACME_RESOLVER_NAME)].acme.dnsChallenge.resolvers = [ "'$(echo "${ACME_DNS_RESOLVER//,/\",\"}")'" ]
                                ' "${CONFIG_PATH}/${CONFIG_FILE}"
                    fi
                ;;
            esac
	    fi

        #### API and dashboard
        print_debug "API Enable"
        if var_true "${ENABLE_API}"; then
            runas   '
                        .api = {}
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            runas   '
                        .api.basePath = "'$(echo "${API_BASE_PATH}")'"
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"


            if var_true "${ENABLE_DASHBOARD}"; then
                if [ ! -f "${middleware_file}" ]; then sudo -u traefik touch "${middleware_file}" ; fi
                middleware_file="${CONFIG_CUSTOM_PATH}/dashboard.yml"
                print_debug "Dashboard Enable"
                sanity_var DASHBOARD_HOSTNAME "Dashboard Hostname e.g. 'traefik.example.com'"
                runas   '
                            .api.dashboard = true
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                runas   '
                            .http.routers.dashboard.service = "api@internal" |
                            .http.routers.dashboard.rule = "Host(`'$(echo "${DASHBOARD_HOSTNAME}")'`) && (PathPrefix(`/api`) || PathPrefix(`/dashboard`))"
                        ' "${CONFIG_PATH}/${CONFIG_FILE}"
                if var_true "${ENABLE_HTTPS}"; then
                    runas   '
                                .http.routers.dashboard.entryPoints = [ env(HTTPS_ENTRYPOINT) ]
                            ' "${CONFIG_PATH}/${CONFIG_FILE}"

                    if var_true "${TLS_ENABLE_ACME}"; then
                        runas   '
                                    .http.routers.dashboard.tls.certresolver = env(ACME_RESOLVER_NAME)
                                ' "${CONFIG_PATH}/${CONFIG_FILE}"
                    else
                        runas   '
                                    .http.routers.dashboard.tls = {}
                                ' "${CONFIG_PATH}/${CONFIG_FILE}"
                    fi
                else
                    runas   '
                                .http.routers.dashboard.entryPoints = [ env(HTTP_ENTRYPOINT) ]
                            ' "${CONFIG_PATH}/${CONFIG_FILE}"

                    runas   '
                                del(.http.routers.dashboard.tls)
                            ' "${CONFIG_PATH}/${CONFIG_FILE}"
                fi
                if [ "${DASHBOARD_AUTHENTICATION_TYPE,,}" = "basic" ]; then
                    runas   '
                                .http.routers.dashboard.middlewares = [ "dashboard-auth" ]
                            ' "${CONFIG_PATH}/${CONFIG_FILE}"
                    dashboard_encrypted_hash=$(htpasswd -nb "${DASHBOARD_AUTHENTICATION_BASIC_ADMIN_USER}" "${DASHBOARD_AUTHENTICATION_BASICADMIN_PASS}")
                    runas   '
                                .http.middlewares.dashboard-auth.basicAuth.users = [ "'$(echo "${dashboard_encrypted_hash}")'" ] |
                                .http.middlewares.dashboard-auth.basicAuth.removeHeader = true
                            ' "${CONFIG_PATH}/${CONFIG_FILE}"
                fi
            else
                runas   '
                            .api.dashboard = false
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi
        else
                runas   '
                            del(.api)
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        #### Logging
        print_debug "Traefik Logging"
        runas   '
                    .log.format = env(LOG_FORMAT) |
                    .log.level = env(LOG_LEVEL)
                ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

        if [ "${LOG_TYPE,,}" = "file" ]; then
            runas   '
                        .log.filePath = "'$(echo "${LOG_PATH}/${LOG_FILE}")'"
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            if [ "${LOG_FORMAT,,}" = "json" ] ; then tlogfmt="json" ; else tlogfmt="standard" ; fi
            create_logrotate traefik "${LOG_PATH%/}"/"${LOG_FILE}" traefik-${tlogfmt} traefik traefik
        fi

        runas       '
                        .accessLog.format = env(ACCESS_LOG_FORMAT) |
                        .accessLog.addInternals = env(ACCESS_LOG_INTERNALS)
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

        if [ "${ACCESS_LOG_TYPE,,}" = "file" ]; then
                runas   '
                            .accessLog.filePath = "'$(echo "${LOG_PATH}/${ACCESS_LOG_FILE}")'"
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

            if [ "${ACCESS_LOG_FORMAT,,}" = "json" ] ; then alogfmt="json" ; else alogfmt="standard" ; fi
            create_logrotate traefik_acess "${LOG_PATH%/}"/"${ACCESS_LOG_FILE}" traefik-access-"${alogfmt}" traefik traefik

            if [ -n "${ACCESS_LOG_BUFFER_SIZE}" ]; then
                runas   '
                            .accessLog.bufferingSize = env(ACCESS_LOG_BUFFER_SIZE)
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi
        fi

        #### Metrics
        if var_true "${ENABLE_METRICS}" ; then
            runas   '
                        .metrics.'$(echo "${METRICS_TYPE}")'.entrypoint = env(METRICS_ENTRYPOINT)
                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
        fi

        #### Ping Information
        if var_true "${ENABLE_PING}"; then
            print_debug "Ping Enable"
            if var_true "${ENABLE_HTTPS}"; then
                runas   '
                            .ping.entryPoint = env(HTTPS_ENTRYPOINT)
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            else
                runas   '
                            .ping.entryPoint = env(HTTP_ENTRYPOINT)
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            fi
        fi

        ### Providers
        #### File
        runas   '
                    .providers.file.directory = "'$(echo "${CONFIG_CUSTOM_PATH}")'" |
                    .providers.file.watch = true
                ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

        #### Docker
        print_debug "Docker Provider"
        if var_true "${ENABLE_DOCKER}"; then
            if var_true "${DOCKER_ENABLE_SWARM_MODE}" ; then
                runas   '
                            .providers.swarm.endpoint = env(DOCKER_ENDPOINT) |
                            .providers.swarm.username = env(DOCKER_USERNAME) |
                            .providers.swarm.password = env(DOCKER_PASSWORD) |
                            .providers.swarm.allowEmptyServices = env(DOCKER_ALLOW_EMPTY_SERVICES) |
                            .providers.swarm.constraints = "" + env(DOCKER_CONSTRAINTS) + "" |
                            .providers.swarm.defaultRule = env(DOCKER_DEFAULT_HOST_RULE) |
                            .providers.swarm.exposedByDefault = env(DOCKER_EXPOSE_CONTAINERS) |
                            .providers.swarm.httpClientTimeout = env(DOCKER_HTTP_TIMEOUT) |
                            .providers.swarm.refreshSeconds = env(DOCKER_SWARM_MODE_REFRESH) |
                            .providers.swarm.useBindPortIP = env(DOCKER_USE_BIND_PORT_IP) |
                            .providers.swarm.watch = true
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

                        if [ -n "${DOCKER_DEFAULT_NETWORK}" ]; then
                            runas   '
                                          .providers.swarm.network = "'$(echo "${DOCKER_DEFAULT_NETWORK}")'"
                                    ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                        fi

                        runas   '
                                .providers.swarm.tls.ca = "'$(echo "${DOCKER_TLS_CERT_PATH}/${DOCKER_TLS_CA_FILE}")'" |
                                .providers.swarm.tls.cert = "'$(echo "${DOCKER_TLS_CERT_PATH}/${DOCKER_TLS_CERT_FILE}")'" |
                                .providers.swarm.tls.key = "'$(echo "${DOCKER_TLS_CERT_PATH}/${DOCKER_TLS_KEY_FILE}")'" |
                                .providers.swarm.tls.insecureSkipVerify = "'$(echo "${DOCKER_TLS_INSECURESKIPVERIFY}")'"
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
            else
                runas   '
                            .providers.docker.endpoint = env(DOCKER_ENDPOINT) |
                            .providers.docker.username = env(DOCKER_USERNAME) |
                            .providers.docker.password = env(DOCKER_PASSWORD) |
                            .providers.docker.allowEmptyServices = env(DOCKER_ALLOW_EMPTY_SERVICES) |
                            .providers.docker.constraints = "" + env(DOCKER_CONSTRAINTS) + "" |
                            .providers.docker.defaultRule = env(DOCKER_DEFAULT_HOST_RULE) |
                            .providers.docker.exposedbyDefault = env(DOCKER_EXPOSE_CONTAINERS) |
                            .providers.docker.httpClientTimeout = env(DOCKER_HTTP_TIMEOUT) |
                            .providers.docker.useBindPortIP = env(DOCKER_USE_BIND_PORT_IP) |
                            .providers.docker.watch = true
                        ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"

                if [ -n "${DOCKER_DEFAULT_NETWORK}" ]; then
                    runas   '
                                .providers.docker.network = "'$(echo "${DOCKER_DEFAULT_NETWORK}")'"
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                fi

                if var_true "${DOCKER_ENABLE_TLS}"; then
                    print_debug "Docker TLS"
                    runas   '
                                .providers.docker.tls.ca = "'$(echo "${DOCKER_TLS_CERT_PATH}/${DOCKER_TLS_CA_FILE}")'" |
                                .providers.docker.tls.cert = "'$(echo "${DOCKER_TLS_CERT_PATH}/${DOCKER_TLS_CERT_FILE}")'" |
                                .providers.docker.tls.key = "'$(echo "${DOCKER_TLS_CERT_PATH}/${DOCKER_TLS_KEY_FILE}")'" |
                                .providers.docker.tls.insecureSkipVerify = "'$(echo "${DOCKER_TLS_INSECURESKIPVERIFY}")'"
                            ' "${CONFIG_PATH%/}"/"${CONFIG_FILE}"
                fi
            fi
        fi

            for snippet in /container/data/traefik/snippets/*; do
                [ -e "${snippet}" ] || continue
                ln -sf "${snippet}" "${CONFIG_CUSTOM_PATH}/$(basename "${snippet}")"
            done
    else
        print_warn "Manual Configuration Mode Activated"
        if [ ! -f "${CONFIG_PATH%/}"/"${CONFIG_FILE}" ]; then
            print_notice "Traefik Configuration File found - Using.."
        fi
    fi
}
